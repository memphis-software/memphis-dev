---
import { getTranslations } from '../i18n/utils';
const { lang = "en" } = Astro.props;

const t = getTranslations(lang);

const slides = t.hero.slides;
---

<div class="relative w-full overflow-hidden h-[70vh] md:h-[90vh]">
  {slides.map((slide, i) => (
    <div class="absolute inset-0 slide opacity-0 transition-opacity duration-1000" id={`slide-${i}`}>
      <img src={`/images/${lang}/slide${i + 1}.jpg`} alt={slide.title} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/50"></div>

      <div class="absolute inset-0 flex items-center justify-center px-6 md:px-16">
        <div id={`text-${i}`} class="text-white max-w-2xl text-center space-y-4">
          <h2 class="text-3xl md:text-5xl font-bold leading-tight">{slide.title}</h2>
          <p class="text-sm md:text-lg opacity-90">{slide.text}</p>
          <div class="flex justify-center">
            <a href="#contact" class="bg-green-500 hover:bg-green-600 px-6 py-3 rounded-lg font-semibold">
              {lang === "en" ? "Get Started" : "Commencer"}
            </a>
          </div>
        </div>
      </div>
    </div>
  ))}
</div>
