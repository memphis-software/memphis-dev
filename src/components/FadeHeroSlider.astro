---
const lang = 'en'; // Hardcoded for now, change to 'fr' for French slides

const slides = lang === 'fr'
  ? [
      { image: '/images/data.jpg', alt: 'Slide 1 FR', title: 'Bienvenue', text: 'Nous créons des solutions modernes.' },
      { image: '/images/data-science.jpg', alt: 'Slide 2 FR', title: 'Nos Projets', text: 'Applications innovantes et évolutives.' },
      { image: '/images/all.png', alt: 'Slide 3 FR', title: 'Travaillez avec nous', text: 'Créons quelque chose de puissant.' },
    ]
  : [
      { image: '/images/data.jpg', alt: 'Slide 1 EN', title: 'Welcome', text: 'We build modern solutions.' },
      { image: '/images/data-science.jpg', alt: 'Slide 2 EN', title: 'Our Projects', text: 'Innovative and scalable apps.' },
      { image: '/images/all.png', alt: 'Slide 3 EN', title: 'Work With Us', text: 'Let’s create something powerful.' },
    ];
---

<div class="relative w-full overflow-hidden h-[70vh] md:h-[90vh]">
  {slides.map((slide, i) => (
    <div class="absolute inset-0 slide opacity-0 transition-opacity duration-1000" id={`slide-${i}`}>
      <img src={slide.image} alt={slide.alt} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/50"></div>

      <div class="absolute inset-0 flex items-center justify-center px-6 md:px-16">
        <div id={`text-${i}`} class="text-white max-w-2xl text-center space-y-4">
          <h2 class="text-3xl md:text-5xl font-bold leading-tight">{slide.title}</h2>
          <p class="text-sm md:text-lg opacity-90 font-bold">{slide.text}</p>
          <div class="flex justify-center">
            <a href="#contact" class="bg-orange-500 hover:bg-green-600 px-6 py-3 rounded-lg font-semibold">
              Get Started
            </a>
          </div>
        </div>
      </div>
    </div>
  ))}

  <!-- Arrows -->
  <button class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/70 p-2 rounded z-10" onclick="prevSlide()">‹</button>
  <button class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/70 p-2 rounded z-10" onclick="nextSlide()">›</button>

  <!-- Dots -->
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex space-x-2 z-10">
    {slides.map((_, i) => (
      <span id={`dot-${i}`} class="w-3 h-3 rounded-full bg-white/50 cursor-pointer" onclick={`goToSlide(${i})`}></span>
    ))}
  </div>
</div>

<script type="module">
  const slidesEl = Array.from(document.querySelectorAll('.slide'));
  const texts = slidesEl.map((slide, i) => document.getElementById(`text-${i}`));
  const dots = slidesEl.map((_, i) => document.getElementById(`dot-${i}`));

  let index = 0;

  function updateDots() {
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-white', i === index);
      dot.classList.toggle('bg-white/50', i !== index);
    });
  }

  function showSlide(newIndex) {
    slidesEl.forEach((slide, i) => {
      slide.style.opacity = i === newIndex ? '1' : '0';
    });

    texts.forEach((text, i) => {
      if (i === newIndex) {
        // Reset animation
        text.classList.remove('animate-slide-left');
        void text.offsetWidth; // trigger reflow
        text.classList.add('animate-slide-left');
      }
    });

    index = newIndex;
    updateDots();
  }

  window.nextSlide = () => showSlide((index + 1) % slidesEl.length);
  window.prevSlide = () => showSlide((index - 1 + slidesEl.length) % slidesEl.length);
  window.goToSlide = (i) => showSlide(i);

  setInterval(() => window.nextSlide(), 5000);

  showSlide(0);
</script>
