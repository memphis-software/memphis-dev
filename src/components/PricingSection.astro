---
import en from '../i18n/en.json';
const { lang = "en" } = Astro.props;
const t = lang === "en" ? { title: "Pricings" } : { title: "Facturation" };

const price = [
  { name: "Starter", feature: lang === "en" ? "Great collaboration!" : "Super collaboration !" },
  { name: "Business", feature: lang === "en" ? "Highly recommended" : "Fortement recommandé" },
  { name: "Premium", featuree: lang === "en" ? "Highly recommended" : "Fortement recommandé" },
];
---

{/** <section class="pricings" id="pricings">
<div class="pricings-container">
  <h2 class="section-title">
    {t.title}
  </h2>
   <div class="pricings-grid">
    {price.map(t => (
      <div class="pricing-card">
        <p class="">"{t.feature}"</p>
        <p class="">"{t.name}"</p>
      </div>
    ))}
  </div>
</section> **/}
<section class="pricing" id="pricings">

  <h2>{en.pricingTitle}</h2>
  <p>{en.pricingDetail}</p>

  <div class="pricing-container">

    <div class="pricing-card">
      <h3>Starter</h3>
      <h4>$150</h4>

      <ul>
        <li>3 to 4 pages website</li>
        <li>Responsive design</li>
        <li>Basic SEO</li>
        <li>Email support</li>
      </ul>

      <a href="#contact" class="pricing-btn">Get Started</a>
    </div>


    <div class="pricing-card featured">
      <h3>Professional</h3>
      <h4>$350</h4>

      <ul>
        <li>Multi-page website</li>
        <li>Responsive design</li>
        <li>Advanced SEO </li>
        <li>Contact form</li>
        <li>Priority support</li>
      </ul>

      <a href="#contact" class="pricing-btn">Get Started</a>
    </div>


    <div class="pricing-card">
      <h3>Premium</h3>
      <h4>$700</h4>

      <ul>
        <li>Custom web application</li>
        <li>Advanced animations</li>
        <li>Advanced SEO </li>
        <li>Database integration</li>
        <li>Maintenance</li>
      </ul>

      <a href="#contact" class="pricing-btn">Get Started</a>
    </div>

  </div>

</section>

