  { name: "Starter", feature: lang === "en" ? "Great collaboration!" : "Super collaboration !" },
  { name: "Business", feature: lang === "en" ? "Highly recommended" : "Fortement recommandé" },
  { name: "Premium", featuree: lang === "en" ? "Highly recommended" : "Fortement recommandé" },
];
