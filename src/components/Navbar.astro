---
const { lang = "en" } = Astro.props;

const links = [
  { href: lang === "en" ? "/en/" : "/fr/", label: lang === "en" ? "Home" : "Accueil" },
  { href: lang === "en" ? "/en/projects" : "/fr/projects", label: lang === "en" ? "Projects" : "Projets" },
  { href: lang === "en" ? "/en/contact" : "/fr/contact", label: lang === "en" ? "Contact" : "Contact" },
];

const switchLangHref = lang === "en" ? "/fr/" : "/en/";
const switchLangLabel = lang === "en" ? "FR" : "EN";
---

<nav style="display:flex; justify-content:space-between; padding:1rem 2rem; background:#111827; color:white;">
  <div style="font-weight:bold;">Memphis Dev</div>

  <ul style="display:flex; list-style:none; gap:1.5rem; margin:0; padding:0;">
    {links.map(link => (
      <li><a href={link.href} style="color:white; text-decoration:none;">{link.label}</a></li>
    ))}
    <li>
      <a href={switchLangHref} style="color:#38bdf8; font-weight:bold;">{switchLangLabel}</a>
    </li>
  </ul>
</nav>
