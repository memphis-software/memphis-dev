---
const { lang = "en" } = Astro.props;

const path = Astro.url.pathname;

// Detect current language from URL instead (more reliable)
const isFrench = path.startsWith("/fr");

// Build links dynamically
const links = [
  { href: isFrench ? "/fr/" : "/en/", label: isFrench ? "Accueil" : "Home" },
  { href: isFrench ? "/fr/services" : "/en/services", label: isFrench ? "Services" : "Services" },
  { href: isFrench ? "/fr/projects" : "/en/projects", label: isFrench ? "Projets" : "Projects" },
  { href: isFrench ? "/fr/pricings" : "/en/pricings", label: isFrench ? "Facturation" : "Pricings" },
  { href: isFrench ? "/fr/contact" : "/en/contact", label: isFrench ? "Contact" : "Contact" },
];

// 🔥 Smart switch (keeps same page)
const switchLangHref = isFrench
  ? path.replace("/fr", "/en")
  : path.replace("/en", "/fr");

const switchLangLabel = isFrench ? "EN" : "FR";
---

<nav><div>Memphis Dev</div>

  <ul>
    {links.map(link => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
    <li>
      <a href={switchLangHref}>{switchLangLabel}</a>
    </li>
  </ul>
</nav>
