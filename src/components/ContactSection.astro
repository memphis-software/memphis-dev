---
const { lang = "en" } = Astro.props;
const t = lang === "en" ? { title:"Contact Us", quest:"Have a project in mind? Let's work together.", name:"Your Name", email:"Your Email", message:"Your Message", send:"Send" } :
                          { title:"Contactez-nous",quest:"Vous avez un projet en tête? Développons-le ensemble.", name:"Votre Nom", email:"Votre Email", message:"Votre Message", send:"Envoyer" };
---

<section class="contact" id="contact">
  <h2>{t.title}</h2>
  <p>{t.quest}</p>
  <div class="contact-container">
  <form class="contact-form">
    <input type="text" placeholder={t.name} required />
    <input type="email" placeholder={t.email} required />
    <textarea placeholder={t.message} rows="6" required></textarea>
    <button type="submit">{t.send}</button>
  </form>
  </div>
</section>
