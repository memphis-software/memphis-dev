---
const { lang = "en" } = Astro.props;
const t = lang === "en" ? { title:"Contact Us", name:"Name", email:"Email", message:"Message", send:"Send" } :
                          { title:"Contactez-nous", name:"Nom", email:"Email", message:"Message", send:"Envoyer" };
---

<section class="section" id="contact">
  <h2 style="font-size:2rem; margin-bottom:2rem; font-weight:bold; color:#f1f5f9;">{t.title}</h2>
  <form style="display:flex; flex-direction:column; gap:1rem;">
    <input type="text" placeholder={t.name} style="padding:0.75rem; border-radius:0.5rem; border:none;"/>
    <input type="email" placeholder={t.email} style="padding:0.75rem; border-radius:0.5rem; border:none;"/>
    <textarea placeholder={t.message} style="padding:0.75rem; border-radius:0.5rem; border:none;"></textarea>
    <button type="submit" style="padding:1rem; border-radius:0.75rem; background:#38bdf8; font-weight:bold; color:#0f172a; border:none;">{t.send}</button>
  </form>
</section>
