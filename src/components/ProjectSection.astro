---
const { lang = "en" } = Astro.props;
const t = lang === "en" ? {
  title: "Our Projects"
} : {
  title: "Nos Projets"
};

const projects = [
  { name: "AI Credit Scoring", desc: lang === "en" ? "Machine learning model predicting loan risks" : "Modèle d'apprentissage automaique (ML) prédisant les risques de prêt." },
  { name: "Business website", desc: lang === "en" ? "Modern responsive websites for companies" : "Sites web modernes s'adaptant à tous types d'écrans (Téléphones, tablettes, ordinateurs.)" },
  { name: "BConnect Platform", desc: lang === "en" ? "Business Networking Platform for entrepreneurs" : "Plateforme de réseautage professionnel pour les entrepreneurs" },
  { name: "Data Dashboard", desc: lang === "en" ? "Interactive analytics dashboard for businesses" : "Tableau de bord analytique et interactif pour les entreprises." }
];
---

{/**   <section class="projects" id="projects">
<div class="projects-container">
  <h2 class="section-title">
    {t.title}
  </h2>
<p class="section-subtitle">Some of the solutions we've built for businesses and digital platforms.</p>
  <div class="projects-grid">
    {projects.map(project => (
      <div class="project-card">
        <h3>{project.name}</h3>
        <p class="contact">{project.desc}</p>
      </div>
    ))}
  </div></div>
</section>  **/}
<section class="projects" id="projects">
  <div class="container">

    <h2 class="section-title">Projects</h2>
    <p class="section-subtitle">
      Some of the solutions we have built for businesses and digital platforms.
    </p>

    <div class="projects-grid">

      <!-- Project 1 -->
      <div class="project-card">
        <img src="/images/project1.jpg" alt="Business Website">

        <div class="project-content">
          <h3>Business Landing Page</h3>

          <p>
            A modern company website built for professional businesses.
          </p>

          <span class="tech">
            Astro • HTML • CSS • JavaScript
          </span>

          <div class="project-buttons">
            <a href="#contact" class="btn">Live Demo</a>
            <a href="#" class="btn-outline">GitHub</a>
          </div>
        </div>
      </div>


      <!-- Project 2 -->
      <div class="project-card">
        <img src="/images/project2.jpg" alt="Client Management">

        <div class="project-content">
          <h3>Client Management System</h3>

          <p>
            A web application allowing businesses to manage their clients and invoices.
          </p>

          <span class="tech">
            PHP • MySQL • JavaScript
          </span>

          <div class="project-buttons">
            <a href="#" class="btn">Live Demo</a>
            <a href="#" class="btn-outline">GitHub</a>
          </div>
        </div>
      </div>


      <!-- Project 3 -->
      <div class="project-card">
        <img src="/images/project3.jpg" alt="AI Credit Scoring">

        <div class="project-content">
          <h3>AI Credit Scoring System</h3>

          <p>
            Machine learning model predicting credit risk using financial data.
          </p>

          <span class="tech">
            Python • Machine Learning • Pandas
          </span>

          <div class="project-buttons">
            <a href="#" class="btn">Live Demo</a>
            <a href="#" class="btn-outline">GitHub</a>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>

