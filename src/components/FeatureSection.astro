---
const { lang = "en" } = Astro.props;
---

<section class="section" id="services">
  <h2 style="font-size:2rem; margin-bottom:3rem; font-weight:bold; color:#f1f5f9;">
    {lang === "en" ? "Our Services" : "Nos Services"}
  </h2>

  <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:2rem;" >
    <div class="card">
      <h3 style="font-size:1.25rem; font-weight:bold; margin-bottom:1rem;">{lang === "en" ? "Web Development" : "Développement Web"}</h3>
      <p style="color:#cbd5e1;">{lang === "en" ? "Clean and modern websites" : "Sites web propres et modernes"}</p>
    </div>

    <div class="card">
      <h3 style="font-size:1.25rem; font-weight:bold; margin-bottom:1rem;">{lang === "en" ? "UI/UX Design" : "Design UI/UX"}</h3>
      <p style="color:#cbd5e1;">{lang === "en" ? "User-centered design" : "Design centré utilisateur"}</p>
    </div>

    <div class="card">
      <h3 style="font-size:1.25rem; font-weight:bold; margin-bottom:1rem;">{lang === "en" ? "Consulting" : "Conseil"}</h3>
      <p style="color:#cbd5e1;">{lang === "en" ? "Strategy and digital guidance" : "Stratégie et accompagnement digital"}</p>
    </div>
  </div>
</section>
