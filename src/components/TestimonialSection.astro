---
const { lang = "en" } = Astro.props;
const t = lang === "en" ? { title: "Testimonials" } : { title: "Témoignages" };

const testimonials = [
  { name: "Alice", message: lang === "en" ? "Great collaboration!" : "Super collaboration !" },
  { name: "Bob", message: lang === "en" ? "Highly recommended" : "Fortement recommandé" },
];
---

<section class="section" id=testimonials">
  <h2 style="font-size:2rem; margin-bottom:3rem; font-weight:bold; color:#f1f5f9;">
    {t.title}
  </h2>

  <div style="display:flex; flex-direction:column; gap:2rem;">
    {testimonials.map(t => (
      <div class="card">
        <p style="font-style:italic; color:#cbd5e1;">"{t.message}"</p>
        <p style="margin-top:0.5rem; font-weight:bold; color:#f1f5f9;">- {t.name}</p>
      </div>
    ))}
  </div>
</section>
