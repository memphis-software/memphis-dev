---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PricingSection from '../../components/PricingSection.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import Footer from '../../components/Footer.astro';
import fr from '../../i18n/fr.json';
import FadeHeroSlider from '../../components/FadeHeroSlider.astro';
const { lang = "fr" } = Astro.props;
---
<BaseLayout title="Memphis Dev | Web & Solutions IA - FR" lang="fr">
  <PricingSection lang="fr" />
  <WhatsAppButton />
  <section style="padding:4rem 2rem; text-align:center;">
    <h3 style="margin:auto;">
      {fr.heroTitle}
    </h>

    <div style="margin-top:2rem;">
      <a href="/en/" style="color:#38bdf8;">English version</a>
    </div>
  </section>
  <Footer lang="fr" />
</BaseLayout>
