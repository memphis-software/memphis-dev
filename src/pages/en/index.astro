import Hero from "../../components/Hero.astro";
import FeatureSection from "../../components/FeatureSection.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import en from "../../i18n/en.json";
---

<BaseLayout title="Memphis Dev - EN" lang="en">
<Hero lang="en" />
<FeatureSection lang="en" />
<WhatsAppButton />
  <section style="padding:4rem 2rem; text-align:center;">
    <h1 style="font-size:2.5rem; max-width:800px; margin:auto;">
      {en.heroTitle}
